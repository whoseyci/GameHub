{
  "name": "skyjo-pro",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "deploy:dry-run": "wrangler deploy --dry-run",
    "check:client": "node scripts/check-client-js.mjs",
    "validate": "npm run typecheck && npm run check:client && npm test -- --run && npm run deploy:dry-run",
    "scaffold:game": "node scripts/scaffold-game.mjs"
  },
  "dependencies": {
    "partyserver": "^0.0.71"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260609.1",
    "typescript": "^5.4.0",
    "vitest": "^4.1.8",
    "wrangler": "^4.98.0"
  }
}
